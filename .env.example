# Copy this file to ".env" and fill in your values.

# Required — your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Optional — which Gemini model to use (default: gemini-2.5-flash)
# Other options: gemini-2.5-flash-lite (cheaper/faster), gemini-2.5-pro (stronger)
GEMINI_MODEL=gemini-2.5-flash

# Optional — port for local runs (default: 3000)
PORT=3000

# Optional — set a shared code to restrict who can use the page.
# Leave blank for an open, public tool.
ACCESS_CODE=
